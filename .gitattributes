# Auto-detect text files
* text=auto eol=lf

# Shell scripts
*.sh text eol=lf
*.bat text eol=crlf

# Source files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# NOTE: Images are intentionally NOT tracked via Git LFS.
# Previous LFS configuration broke all images on HuggingFace Spaces
# (Docker COPY . . only copies 131-byte pointer files, not real images).
# Images are now committed directly to the repo as binary files.
