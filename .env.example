# ═══════════════════════════════════════════════════════════════
# Elbaz LMS — Environment Variables Template
# ═══════════════════════════════════════════════════════════════
# ⚠️  Copy this file to .env and fill in ALL values before deploying.
#
# Generate secrets:
#   openssl rand -base64 64   → for APP_SECRET and WATERMARK_SECRET
#   openssl rand -hex 32      → for DB_PASSWORD and DB_ROOT_PASSWORD
# ═══════════════════════════════════════════════════════════════

# ─── Environment ───────────────────────────────────────────────
NODE_ENV=production

# ─── Core App ──────────────────────────────────────────────────
APP_ID=elbaz-lms
APP_SECRET=GENERATE_WITH_openssl_rand_base64_64
PORT=3000

# ─── Database (used by drizzle-kit only, Docker overrides this) ─
DATABASE_URL=mysql://root:password@localhost:3306/elbaz_platform

# ─── Docker MySQL (REQUIRED for docker-compose) ───────────────
DB_ROOT_PASSWORD=GENERATE_WITH_openssl_rand_hex_32
DB_NAME=elbaz_platform
DB_USER=elbaz
DB_PASSWORD=GENERATE_WITH_openssl_rand_hex_32

# ─── Video Protection ──────────────────────────────────────────
# HMAC key for signing video URLs and watermark tokens
WATERMARK_SECRET=GENERATE_WITH_openssl_rand_base64_64

# ─── Cloudflare R2 (Video Storage — S3-compatible) ────────────
# Get these from: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_BUCKET=elbaz-videos
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# ─── Paymob (Egypt Payment Gateway) ───────────────────────────
# Get these from: https://portal.paymob.com/dashboard
# API Key: from Settings → API Keys
# Integration IDs: from Developers → Integrations
# HMAC Secret: from Developers → Webhooks (after adding webhook URL)
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_HMAC_SECRET=your_paymob_hmac_secret
PAYMOB_BASE_URL=https://accept.paymob.com/api
PAYMOB_INTEGRATION_ID=your_default_integration_id
PAYMOB_INTEGRATION_CARD=your_card_integration_id
PAYMOB_INTEGRATION_WALLET=your_wallet_integration_id
PAYMOB_INTEGRATION_PAYPAL=your_paypal_integration_id
PAYMOB_INTEGRATION_CASH=your_cash_integration_id
PAYMOB_INTEGRATION_KIOSK=your_kiosk_integration_id

# ─── Redis (Rate Limiting + Caching) ─────────────────────────
# Docker sets this automatically to redis://redis:6379
# Only needed if running outside Docker
REDIS_URL=redis://localhost:6379

# ─── Email (for password reset, notifications) ────────────────
# Provider: console (dev) | resend (recommended) | sendgrid | smtp
EMAIL_PROVIDER=console
EMAIL_FROM="Elbaz Platform <noreply@yourdomain.com>"

# Resend.com (recommended — free tier: 100 emails/day)
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=

# SendGrid (alternative)
SENDGRID_API_KEY=

# SMTP (alternative — e.g., Gmail with App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Frontend URL (for CORS + password reset links) ───────────
FRONTEND_URL=https://yourdomain.com

# ─── CORS (comma-separated allowed origins) ───────────────────
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ─── Kimi OAuth (Optional — server starts without it) ─────────
KIMI_AUTH_URL=
KIMI_OPEN_URL=
OWNER_UNION_ID=

# ─── AI Chatbot (Optional — OpenAI-compatible API) ────────────
CHATBOT_API_KEY=
CHATBOT_API_BASE=https://api.openai.com/v1
CHATBOT_MODEL=gpt-4o-mini
