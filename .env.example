# ═══════════════════════════════════════════════════════════════
# Elbaz Platform — Environment Variables Reference
# ═══════════════════════════════════════════════════════════════
# ⚠️  This file is for REFERENCE only. The real values must be placed
#     in the ".env" file (or your hosting platform's secrets manager).
#     NEVER commit .env to git. It's already in .gitignore.
# ═══════════════════════════════════════════════════════════════
#
# REQUIRED (server will refuse to start in production if missing):
#   - NODE_ENV, PORT, HOST
#   - APP_SECRET (≥32 chars — use `openssl rand -base64 64`)
#   - DATABASE_URL (Aiven MySQL with ?ssl-mode=REQUIRED)
#   - GOOGLE_CLIENT_ID (Google OAuth — env.ts hard-requires this)
#
# RECOMMENDED (functionality degrades without these):
#   - DATABASE_SSL_CA (download from Aiven Console → Overview → CA Certificate)
#   - RESEND_API_KEY + EMAIL_FROM (password reset / verification emails)
#   - R2_* (Cloudflare R2 for video streaming — without it, videos won't play)
#   - PAYMOB_API_KEY + PAYMOB_INTEGRATION_ID + PAYMOB_IFRAME_ID + PAYMOB_HMAC_SECRET (payments)
#   - SENTRY_DSN (error monitoring)
#   - CLARITY_ID or CLARITY_PROJECT_ID (analytics)
#   - OPENROUTER_API_KEY (AI chatbot — only fallback tier)
#
# OPTIONAL (enable additional features):
#   - REDIS_URL (distributed rate limiting + cache — single-instance OK without)
#   - MODAL_API_KEY, GROQ_API_KEY, NVIDIA_API_KEY (premium chatbot tiers)
#   - WATERMARK_SECRET (≥32 chars — video piracy tracing)
#   - ADMIN_PASSWORD (initial admin password — auto-generated if unset)
# ═══════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=7860
HOST=0.0.0.0

# ── Security ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
# Used for: JWT signing, 2FA backup code HMAC, session integrity.
# MUST be ≥32 characters. NEVER commit. Rotate if leaked.
APP_SECRET=your_random_64_char_secret_here_MINIMUM_32_CHARS

# ── JWT ────────────────────────────────────────────────────────
# Access token TTL — sliding session auto-refreshes when <2h remaining.
JWT_ACCESS_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# ── Database (Aiven MySQL) ─────────────────────────────────────
# Get from: Aiven Console → your service → Overview → Connection information
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl-mode=REQUIRED
DATABASE_URL=mysql://avnadmin:YOUR_PASSWORD@YOUR_HOST.aivencloud.com:27038/defaultdb?ssl-mode=REQUIRED

# 🔒 SECURITY: Download the CA certificate from Aiven Console and paste
# its contents here (or save to a file and reference the path). Without
# this, the connection falls back to rejectUnauthorized:false which is
# vulnerable to man-in-the-middle attacks.
# Get from: Aiven Console → Overview → CA Certificate (Download)
DATABASE_SSL_CA=-----BEGIN CERTIFICATE-----\nYOUR_AIVEN_CA_CERT_HERE\n-----END CERTIFICATE-----

# ── Google OAuth ───────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Create "OAuth 2.0 Client ID" → Type: "Web application"
# Add https://ahmedelbaz.qzz.io/api/google-auth/callback to "Authorized redirect URIs"
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_OAUTH_REDIRECT_URI=https://ahmedelbaz.qzz.io/api/google-auth/callback

# ── Email (Resend.com) ─────────────────────────────────────────
# Get from: https://resend.com → API Keys
# For production, verify your domain at Resend → Domains
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=onboarding@resend.dev
EMAIL_PROVIDER=resend

# ── File Storage (Cloudflare R2) ───────────────────────────────
# Get from: https://dash.cloudflare.com → R2 → your bucket → Settings
# Create an API token with "Object Read & Write" permission for the bucket.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET=elbaz-videos
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# Optional: public URL if you serve R2 via a custom domain (Cloudflare Worker)
# R2_PUBLIC_URL=https://cdn.ahmedelbaz.qzz.io

# ── Payment (Paymob) ───────────────────────────────────────────
# Get from: https://accept.paymob.com → Settings → Account Info
# Integration IDs: Settings → Payment Methods → activate the ones you need
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_HMAC_SECRET=your_paymob_hmac_secret
PAYMOB_INTEGRATION_ID=12345
PAYMOB_IFRAME_ID=67890
PAYMOB_BASE_URL=https://accept.paymob.com
# Optional: per-method integration IDs (override PAYMOB_INTEGRATION_ID)
# PAYMOB_INTEGRATION_CARD=12345
# PAYMOB_INTEGRATION_WALLET=23456
# PAYMOB_INTEGRATION_BANK=34567
# PAYMOB_INTEGRATION_KIOSK=45678
# PAYMOB_INTEGRATION_CASH=56789

# ── AI Chatbot (4-tier cascade) ────────────────────────────────
# At least ONE of these must be set for the chatbot to work.
# The cascade tries each in order: MODAL → GROQ → NVIDIA → OPENROUTER.
# If you only want basic chatbot, set OPENROUTER_API_KEY (free tier).

# TIER 1 — Modal (GLM-5.1-FP8 reasoning model) — BEST QUALITY
# Get from: https://modal.com → Settings → API Keys
# MODAL_API_KEY=modal-XXXXXXXXXXXXX

# TIER 2 — Groq (Llama 3.3, Qwen 3, Llama 4 Scout) — FREE ULTRA-FAST
# Get from: https://console.groq.com → API Keys
# GROQ_API_KEY=gsk_XXXXXXXXXXXXX

# TIER 2.5 — NVIDIA (MiniMax-M3) — FAST with NVIDIA API key
# Get from: https://build.nvidia.com → Account → API Keys
# NVIDIA_API_KEY=nvapi-XXXXXXXXXXXXX

# TIER 3 — OpenRouter (free model cascade) — LAST RESORT
# Get from: https://openrouter.ai → Keys
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Redis (Optional — distributed cache + rate limiting) ───────
# Without Redis, the app uses in-memory caches (single-instance only).
# On HF Spaces (single instance) this is fine. For HPA / multi-pod, set this.
# REDIS_URL=redis://localhost:6379

# ── Rate Limiting ──────────────────────────────────────────────
# Global API rate limit (per IP). Auth endpoints have stricter per-action limits.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300

# ── Frontend ───────────────────────────────────────────────────
FRONTEND_URL=https://ahmedelbaz.qzz.io
CORS_ORIGINS=https://ahmedelbaz.qzz.io

# ── Monitoring ─────────────────────────────────────────────────
# Sentry: https://sentry.io → your project → Settings → Client Keys
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Microsoft Clarity: https://clarity.microsoft.com → your project → Settings
# Either CLARITY_ID or CLARITY_PROJECT_ID works (CLARITY_ID is the HF Spaces convention).
CLARITY_ID=your_clarity_project_id_10_chars

# ── Mobile App (Capacitor) ─────────────────────────────────────
VITE_API_URL=https://ahmedelbaz.qzz.io

# ── Optional ───────────────────────────────────────────────────
# Watermark secret for video piracy tracing (≥32 chars)
WATERMARK_SECRET=your_random_watermark_secret_here_MINIMUM_32_CHARS

# Initial admin password (auto-generated if empty — check server logs on first boot)
# ADMIN_PASSWORD=YourStrongAdminPassword123

# Webhook secret for GitHub integration (optional)
# WEBHOOK_SECRET=your_webhook_secret
