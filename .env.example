# ═══════════════════════════════════════════════════════════════
# Elbaz Platform — Production Environment Configuration
# ═══════════════════════════════════════════════════════════════
# ⚠️  IMPORTANT: This file is for REFERENCE only.
#     The real values must be placed in the ".env" file.
#     NEVER commit .env to git. Add it to .gitignore!
# ═══════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=7860
HOST=0.0.0.0

# ── Security ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=your_random_64_char_secret_here

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/elbaz_platform

# ── Google OAuth ───────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Create "OAuth 2.0 Client ID" → Type: "Web application"
# Add your domain to "Authorized JavaScript Origins"
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# ── Email (Resend.com) ─────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_XXXXXXXXXX
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── File Storage (Cloudflare R2) ───────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=elbaz-platform

# ── Payment (Paymob) ───────────────────────────────────────────
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_HMAC_SECRET=your_paymob_hmac_secret
PAYMOB_INTEGRATION_ID=your_integration_id

# ── AI Chatbot (OpenRouter) ────────────────────────────────────
OPENROUTER_API_KEY=sk-or-XXXXXXXXXXXXX

# ── Mobile App (Capacitor) ─────────────────────────────────────
# This is the URL your mobile app will call to reach the backend.
# Must be the HTTPS URL of your deployed server.
VITE_API_URL=https://ahmedelbaz.qzz.io

# ── Frontend ───────────────────────────────────────────────────
FRONTEND_URL=https://ahmedelbaz.qzz.io

# ── Optional ───────────────────────────────────────────────────
WATERMARK_SECRET=your_random_watermark_secret_here
ADMIN_PASSWORD=YourStrongAdminPassword123
