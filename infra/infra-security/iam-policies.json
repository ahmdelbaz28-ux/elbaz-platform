  "huggingface_secrets_policy": {
    "name": "hf-secrets-access",
    "description": "Policy for accessing Hugging Face API secrets stored in Vault",
    "path": "secret/data/integrations/huggingface",
    "capabilities": ["read"],
    "allowed_services": ["backend-app", "ml-training-pipeline"],
    "rotation_period": "720h",
    "max_ttl": "2160h"
  },
  "aiven_database_policy": {
    "name": "aiven-app-user",
    "database": "ahmedelbaz_lms",
    "privileges": [
      "SELECT",
      "INSERT",
      "UPDATE",
      "DELETE"
    ],
    "denied_privileges": [
      "DROP",
      "ALTER",
      "GRANT",
      "REVOKE",
      "CREATE",
      "TRUNCATE",
      "REFERENCES",
      "INDEX",
      "ALL PRIVILEGES"
    ],
    "tables": "*",
    "with_grant_option": false,
    "connection_source": "kubernetes_namespace:ahmedelbaz",
    "timeout": "30s",
    "max_connections": 50,
    "statement_timeout": "60s",
    "idle_in_transaction_session_timeout": "300s"
  }
}
