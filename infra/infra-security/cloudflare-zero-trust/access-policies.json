    "session_duration": "300s",
    "challenge_sensitivity": "medium",
    "rules": [
      {
        "name": "Block Automated Bots on API",
        "expression": "(http.request.uri.path contains \"/api/\" and cf.bot_management.score lt 30 and http.request.method eq \"POST\")",
        "action": "block"
      },
      {
        "name": "Challenge Suspicious Bots",
        "expression": "cf.bot_management.score lt 15",
        "action": "challenge"
      },
      {
        "name": "Allow Verified Bots",
        "expression": "cf.bot_management.verified_bot eq true",
        "action": "skip"
      }
    ]
  },
  "gateway": {
    "enabled": true,
    "dns_filtering": {
