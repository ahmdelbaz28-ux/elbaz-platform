# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Email ─────────────────────────────────────────────────────
# ⚠️ Change to "resend" after setting up Resend account
EMAIL_PROVIDER=console
EMAIL_FROM="Elbaz Platform <noreply@yourdomain.com>"
RESEND_API_KEY=

# ─── Frontend URL ──────────────────────────────────────────────
# ⚠️ Change "yourdomain.com" to your actual domain
FRONTEND_URL=https://yourdomain.com

# ─── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ─── Kimi OAuth (Optional — leave empty) ─────────────────────
KIMI_AUTH_URL=
KIMI_OPEN_URL=
OWNER_UNION_ID=

# ─── AI Chatbot (Optional — leave empty) ──────────────────────
CHATBOT_API_KEY=
CHATBOT_API_BASE=https://api.openai.com/v1
CHATBOT_MODEL=gpt-4o-mini
