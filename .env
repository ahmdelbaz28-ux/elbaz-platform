# ═══════════════════════════════════════════════════════════════
# Elbaz LMS — .env (DEPLOY READY — Fill in the GENERATE_ values)
# ═══════════════════════════════════════════════════════════════
# ⚠️  احذر! هذا الملف فيه بيانات حساسة — لا ترسله لأي شخص!
# ⚠️  Fill in every GENERATE_ value before deploying!
# ═══════════════════════════════════════════════════════════════

# ─── Environment ───────────────────────────────────────────────
NODE_ENV=production

# ─── Core App ──────────────────────────────────────────────────
APP_ID=elbaz-lms
APP_SECRET=GENERATE_WITH_openssl_rand_base64_64
PORT=3000

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=mysql://root:password@localhost:3306/elbaz_platform

# ─── Docker MySQL (REQUIRED) ──────────────────────────────────
DB_ROOT_PASSWORD=GENERATE_WITH_openssl_rand_hex_32
DB_NAME=elbaz_platform
DB_USER=elbaz
DB_PASSWORD=GENERATE_WITH_openssl_rand_hex_32

# ─── Video Protection ──────────────────────────────────────────
WATERMARK_SECRET=GENERATE_WITH_openssl_rand_base64_64

# ─── Cloudflare R2 (Video Storage) ────────────────────────────
# ⚠️ Fill these after creating your Cloudflare account + R2 bucket
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_BUCKET=elbaz-videos
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# ═══════════════════════════════════════════════════════════════
# ✅ PAYMOB — Real Keys (Already Configured)
# ═══════════════════════════════════════════════════════════════
PAYMOB_API_KEY=ZXlKaGJHY2lPaUpJVXpVeE1pSXNJblI1Y0NJNklrcFhWQ0o5LmV5SmpiR0Z6Y3lJNklrMWxjbU5vWVc1MElpd2ljSEp2Wm1sc1pWOXdheUk2TVRFMU9URTROU3dpYm1GdFpTSTZJbWx1YVhScFlXd2lmUS50MG9QS0J0UlJKSi1PckpTcmw5VFAtMGVORldkNVJjZkExN1VzUnJpeVE5ZFNSTkRPRUFhR0k5dmFpbGItNF96Tm5wVFlVb0tHYjYtcnFXOGFiM1hzdw==
