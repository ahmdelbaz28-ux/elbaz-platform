# ── Dependencies ──
node_modules/

# ── Build output ──
.next/
dist/
build/
*.tsbuildinfo
dist-electron/

# ── Environment & Secrets ─────────────────────────────────────────────
# 🔒 SECURITY: every env file containing real values must be ignored.
# Use `.env.example` (committed) as the template; never commit real secrets.
.env
.env.*
!.env.example
!.env.test

# ── Credentials / Certificates / Keys ────────────────────────────────
# 🔒 SECURITY: any kind of credential file must never be tracked.
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
*.jks
*.keystore
ca-*.pem
*-ca.pem
service-account*.json
*.service-account.json
deploy-key*
id_rsa*
id_ed25519*
*.ppk
.env.secret
secrets.*
!secrets.example

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS ──
.DS_Store
Thumbs.db
desktop.ini

# ── Project-specific ──
upload/
skills/
download/
worklog.md
agent-ctx/

# ── Testing / Coverage ──
test-results/
coverage/
.nyc_output/
.turbo/
.vercel/

# ── Cache ──
.cache/
.eslintcache
*.cache
.parcel-cache/

# ── Large binary files (prevent accidental commits) ──
*.tar.gz
*.tgz
*.tar.bz2
*.zip
*.rar
*.7z
*.dmg
*.iso
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.wav
*.mp3
*.flac
*.aac
*.psd
*.ai
*.svgz

# ── Data snapshots / exports (large, not needed in production) ──
repo-main.json
repo-page.json
repo_main.json
user_profile.json
*.sql.bak

# ── Mobile / Desktop build artifacts ──
android/app/build/
android/.gradle/
android/captures/
android/local.properties
ios/Pods/
ios/build/
dist-electron/

# ── Editor / IDE ──
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo

# ── Cloudflare Wrangler ──
.wrangler/

# ── LFS (managed by .gitattributes) ──
# Add any binary that must be tracked via git-lfs here
